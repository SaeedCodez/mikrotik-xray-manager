# ---- Required ----
# Password to unlock the web UI. If blank, ANY password is accepted (demo mode).
APP_PASSWORD=change_me

# ---- Optional (defaults shown) ----
# Port the web UI listens on.
APP_PORT=8080

# Directory for JSON state + the generated xray config.
DATA_DIR=./data

# Path to the xray-core binary the app manages.
XRAY_BINARY=/usr/local/bin/xray

# Where the app writes the active xray config (defaults to $DATA_DIR/xray/config.json).
XRAY_CONFIG_PATH=./data/xray/config.json

# SOCKS5 inbound port xray listens on (what other apps/MikroTik connect to).
XRAY_INBOUND_PORT=10808

# HTTP inbound port xray listens on.
XRAY_INBOUND_HTTP_PORT=10809

# URL fetched through each proxy to measure real delay (latency test).
HEALTH_TEST_URL=http://www.gstatic.com/generate_204

# Secret used to sign session cookies (HMAC-SHA256). Use a long random string.
# If unset, an ephemeral secret is generated and sessions reset on every restart.
SESSION_SECRET=please_change_to_a_random_32+_char_string
